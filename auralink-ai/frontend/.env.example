## Backend API (required in production)
# Prefer NEXT_PUBLIC_API_URL so the browser can call Cloud Run (must be NEXT_PUBLIC_*).
# On Vercel you can use AURALINK_BACKEND_URL instead — next.config maps it to NEXT_PUBLIC_API_URL at build.
# NEXT_PUBLIC_API_URL=https://your-service-xxxxx.run.app
# AURALINK_BACKEND_URL=https://your-service-xxxxx.run.app

## Clerk (required for auth)
# Get these from Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

## Clerk JWT template (recommended when calling your own backend)
# Clerk Dashboard → JWT Templates → create e.g. "backend"
# - For client-side: NEXT_PUBLIC_CLERK_JWT_TEMPLATE=backend
# - For server-side /api/clerk/token: CLERK_JWT_TEMPLATE=backend
NEXT_PUBLIC_CLERK_JWT_TEMPLATE=backend
CLERK_JWT_TEMPLATE=backend

## Clerk URLs (recommended)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard/home
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard/home

## Publishing API (Vercel build): rewrite /__synclyst_publishing/* → this URL. Defaults to Cloud Run in next.config when VERCEL=1.
# PUBLISHING_PROXY_TARGET=https://synclyst-publishing-xxxxx.us-central1.run.app

## App URL (used for Stripe success/cancel redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

## If marketing pages are static on another domain (e.g. synclyst.app) but the Next app is on *.vercel.app,
## set this to the Next deployment origin (no trailing slash). Injects into landing.html meta synclyst-app-origin.
## Leave empty when everything is on the same host (recommended — scan → flow uses sessionStorage).
# NEXT_PUBLIC_SYNCLYST_APP_ORIGIN=https://your-next-app.vercel.app

## Stripe (required for payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

## Shopify (required for webhook verification / approval checks)
# Partners → App → API credentials → "API secret key" (same value used for webhook HMAC).
SHOPIFY_API_SECRET=shpss_...
# Optional alias some docs use (same value as SHOPIFY_API_SECRET):
# SHOPIFY_CLIENT_SECRET=shpss_...
# Do NOT set SHOPIFY_WEBHOOK_SECRET unless it matches the API secret — it overrides SHOPIFY_API_SECRET and will break HMAC if wrong.

## Waitlist (demo + flow-3) — server route POST /api/waitlist → Supabase table waitlist_signups
# Required on Vercel (Production) for synclyst.app “Join waitlist” to work. Use service_role, not anon.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # or SUPABASE_SERVICE_KEY= (same value as publishing uses)

