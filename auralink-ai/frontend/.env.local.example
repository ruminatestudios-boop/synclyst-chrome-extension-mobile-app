# =============================================================================
# AuraLink AI Frontend - Production environment configuration
# Copy to .env.local and set values. Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API URL (injected into landing.html at build; used by dashboard)
# Dev:  http://localhost:8000
# Prod: https://api.yourdomain.com (or your backend URL)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Publishing JWT — MUST match JWT_SECRET in auralink-ai/publishing/.env so
# GET /api/publishing/token and the publishing API verify the same HS256 key.
# Default dev value (used by npm run dev:all from repo root):
PUBLISHING_JWT_SECRET=dev-secret-change-in-production
JWT_SECRET=dev-secret-change-in-production

# -----------------------------------------------------------------------------
# Publishing API (listings, enabled platforms, Shopify connect). For local flow testing.
# Dev:  http://localhost:8001  (run: cd auralink-ai/publishing && npm run dev)
# Next rewrites /__synclyst_publishing/* → this port when not on Vercel.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PUBLISHING_API_URL=http://localhost:8001
# Optional: explicit base for server redirects to publishing (Shopify OAuth). Defaults to NEXT_PUBLIC_PUBLISHING_API_URL.
# PUBLISHING_APP_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# Clerk (from https://dashboard.clerk.com – use same app as backend)
# Publishable key is safe for client; secret is server-only.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx

# -----------------------------------------------------------------------------
# Shopify (required for webhook verification / approval checks)
# Use your app's "API secret key" from Shopify Partners.
# -----------------------------------------------------------------------------
SHOPIFY_API_SECRET=shpss_xxx

# -----------------------------------------------------------------------------
# Waitlist (demo “Join waitlist” → POST /api/waitlist). Same Supabase project as publishing.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role from Supabase → Settings → API
# -----------------------------------------------------------------------------
# Optional: Clerk JS URL / version override (only if needed)
# NEXT_PUBLIC_CLERK_JS_URL=
# NEXT_PUBLIC_CLERK_JS_VERSION=
# -----------------------------------------------------------------------------
