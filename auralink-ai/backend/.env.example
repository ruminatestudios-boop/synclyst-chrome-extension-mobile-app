# =============================================================================
# SyncLyst Backend - Production environment configuration
# Copy to .env and set values. Never commit .env to version control.
# =============================================================================
#
# DUMMY RUN (explicit only):
# - Leave SUPABASE_URL and SUPABASE_SERVICE_KEY empty (or omit them).
# - Set FORCE_DUMMY_VISION=true if you want demo extraction responses.
# - Without FORCE_DUMMY_VISION=true, missing API keys return 503 (no fake success).
# - Set CORS_ORIGINS= or CORS_ORIGINS=* (or add http://localhost:3000) for local frontend.
# Then: start backend (uvicorn), start frontend, open Try product scan → upload/capture
#       → you get dummy extraction → Save as draft → list products (in-memory). No DB or API keys needed.
#
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (PostgreSQL)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# -----------------------------------------------------------------------------
# Vision / AI (use one or the other depending on VISION_PROVIDER)
# -----------------------------------------------------------------------------
VISION_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
# OPENAI_API_KEY=your_openai_api_key
FORCE_DUMMY_VISION=false

# After image extraction, fetch exact product name and full listing from the web (Gemini + Google Search).
# Set true for strongest product recognition (brand, model, year from web). Requires GEMINI_API_KEY.
# ENABLE_WEB_ENRICHMENT=true

# Optional: Google Cloud Vision for OCR (better label text than Tesseract). Paste full JSON from GCP service account.
# GCP_VISION_CREDENTIALS_JSON={"type":"service_account",...}

# -----------------------------------------------------------------------------
# Redis (production Redis for Celery / background tasks)
# -----------------------------------------------------------------------------
REDIS_URL=redis://:password@your-redis-host:6379/0

# -----------------------------------------------------------------------------
# Clerk (JWT verification for API – match frontend app)
# From https://dashboard.clerk.com
# -----------------------------------------------------------------------------
CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx

# -----------------------------------------------------------------------------
# Stripe (subscriptions)
# Create products/prices in Stripe Dashboard and paste the Price IDs here.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_SCALE=price_xxx
STRIPE_CUSTOMER_PORTAL_RETURN_URL=https://synclyst.app/dashboard

# -----------------------------------------------------------------------------
# CORS – allowed origins for your frontend (comma-separated)
# Production: set to your frontend URL(s). Leave empty or * for allow-all (dev).
# For local dev (e.g. frontend on http://localhost:3000), use empty or * or add http://localhost:3000.
# -----------------------------------------------------------------------------
# Local dev (uncomment one of these if you get "Couldn't reach the server" on scan):
# CORS_ORIGINS=
# CORS_ORIGINS=http://localhost:3000
CORS_ORIGINS=https://synclyst.app,https://www.synclyst.app

# -----------------------------------------------------------------------------
# Optional: path to JSON file with known brands for OCR/label matching (canonical names).
# Example: backend/data/brands-sample.json (lowercase key → display name).
# BRANDS_DB_PATH=data/brands-sample.json
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Quotas — starter tier (free scans per month before 402 / waitlist)
# Default 3. Set to 1 locally to test the waitlist popup after a single scan; remove or set 3 for production.
# STARTER_SCAN_LIMIT=3
# STARTER_SCAN_LIMIT=1

# -----------------------------------------------------------------------------
# Shopify OAuth (required for Connect Shopify in the app)
# Create an app at https://partners.shopify.com, get Client ID and Client secret.
# Without these, the install endpoint returns "Shopify app not configured".
# APP_BASE_URL=https://api.yourdomain.com
# FRONTEND_URL=https://app.yourdomain.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Public Developer API — Stripe Plan Price IDs
# Create these Products in Stripe Dashboard → Products → Add Product.
# Free plan: no Stripe price needed.
# Starter: £19/month recurring, name "Synclyst API Starter"
# Pro:     £49/month recurring, name "Synclyst API Pro"
# Enterprise: custom / contact sales
# -----------------------------------------------------------------------------
STRIPE_PRICE_DEV_STARTER=price_xxx
STRIPE_PRICE_DEV_PRO=price_xxx
STRIPE_PRICE_DEV_ENTERPRISE=
# -----------------------------------------------------------------------------
# Integrations: webhook secret for listing-published (optional)
# Set to verify POST /api/v1/integrations/webhooks/listing-published
# -----------------------------------------------------------------------------
# INTEGRATIONS_WEBHOOK_SECRET=
# -----------------------------------------------------------------------------
