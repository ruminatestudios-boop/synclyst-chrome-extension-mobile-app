{
  "name": "auralink-publishing-api",
  "version": "1.0.0",
  "description": "Multi-platform listing publish API for AuraLink",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dev:serve": "node src/index.js",
    "test:translators": "node scripts/test-translators.js",
    "shopify:login": "npx @shopify/cli@latest auth login",
    "shopify:deploy-config": "npx @shopify/cli@latest app deploy --path . --no-build --allow-updates",
    "deploy:cloud-run": "bash scripts/deploy-cloud-run.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2"
  }
}
